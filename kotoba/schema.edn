;; chie 智慧 — AI-ecosystem ontology / kotoba schema (ADR-2606171200)
;; The AI sibling of the power-mirror lineage (tsumugi / keizu / kabuto / kanjō / kosatsu).
;; 取-concentration (compute / capital / talent / policy-influence) routed to OPENING.
;; map-not-target · non-adjudicating · edge-primary · never-trades.

{:schema/id  :ai-ecosystem
 :schema/adr "ADR-2606171200"

 ;; ── node kinds (:organism/kind) ─────────────────────────────────────────────
 :node/kinds
 [{:k ":ai.org/lab"            :doc "frontier / AI lab (OpenAI/Anthropic/DeepMind/xAI/Mistral/DeepSeek…)"}
  {:k ":ai.org/company"        :doc "AI product / cloud / chip company (NVIDIA/Microsoft/Google/Amazon/TSMC…)"}
  {:k ":ai.org/research"       :doc "university / public research institute (Stanford HAI / AIST / MILA…)"}
  {:k ":ai.org/standards"      :doc "standards / governance body (NIST / ISO-IEC JTC1 SC42 / Frontier Model Forum / MLCommons)"}
  {:k ":ai.org/funder"         :doc "VC / SWF / strategic investor (a16z / Sequoia / SoftBank / MGX)"}
  {:k ":ai.org/state"          :doc "regulator / government body (EU AI Office / US AISI / UK AISI / 内閣府)"}
  {:k ":ai.role/person"        :doc "public-power ROLE only (founder/chair/chief-scientist/regulator). NO private profile (G2)"}
  {:k ":ai.invest/round"       :doc "funding round / M&A (DISCLOSED only). R1 — absent in R0 seed (coverage gap)"}
  {:k ":ai.policy/instrument"  :doc "regulation / soft-law text (EU AI Act / 広島プロセス / Bletchley)"}
  {:k ":ai.asset/model"        :doc "published model/weights. :ai/open? flags the weights, NOT a capability grade (N3/G4)"}
  {:k ":ai.asset/compute"      :doc "compute cluster / datacenter. Detail → kasa / handotai. R1 — absent in R0 seed"}]

 ;; ── node attributes ─────────────────────────────────────────────────────────
 :node/attrs
 [{:a ":organism/id"        :v :string  :doc "e.g. ai.lab.openai / ai.policy.eu-ai-act"}
  {:a ":organism/kind"      :v :keyword}
  {:a ":organism/label"     :v :string}
  {:a ":organism/sourcing"  :v :keyword :enum [":representative" ":authoritative"]
                            :doc "representative = bounded seed / authoritative = primary-source live (G7-gated)"}
  {:a ":organism/nests-in"  :v :string  :doc "child → parent (DeepMind → Google; GPT → OpenAI)"}
  {:a ":ai/sector"          :v :keyword :doc ":frontier-lab :chip :foundry :cloud :vc :swf :regulator :open-weights …"}
  {:a ":ai/open?"           :v :boolean :doc "open-weights / open-compute / public standard — the OPENING-routing basis"}
  {:a ":ai/role"            :v :string  :doc "public role descriptor for :ai.role/person nodes"}
  {:a ":ai/round-amount-usd" :v :long   :doc "DISCLOSED funding-round amount (USD); a fact, never a valuation verdict (N3)"}]

 ;; ── 縁 (edges) — 取 lives ONLY here (N1) ─────────────────────────────────────
 :edge/kinds
 [{:e ":invests-in"    :axis :capital :doc "funder/company → lab (capital accumulation)"}
  {:e ":compute-deal"  :axis :compute :doc "chip/cloud → lab (compute accumulation + lock-in/fragility)"}
  {:e ":talent-flow"   :axis :talent  :doc "org → org talent movement (AGGREGATE only; no individual tracking, G2)"}
  {:e ":governs"       :axis :policy  :doc "state/instrument → lab (regulatory reach)"}
  {:e ":sets-standard" :axis :policy  :doc "standards body → spec/member (normative reach)"}
  {:e ":partners"      :axis nil      :doc "reciprocal partnership (feeds no axis)"}
  {:e ":holds-role"    :axis nil      :doc "person-role → org (structural; public role only)"}
  {:e ":depends-on"    :axis nil      :doc "lab → foundry/chip (feeds fragility; detail → handotai/kabuto)"}]

 :edge/attrs
 [{:a ":en/from"          :v :string}
  {:a ":en/to"            :v :string}
  {:a ":en/kind"          :v :keyword}
  {:a ":en/grasping-load" :v :double  :doc "∈ [0,1] lock-in/dependency weight — where 取 lives"}
  {:a ":en/sourcing"      :v :keyword :enum [":representative" ":authoritative"]}
  {:a ":en/disclosed-src" :v :string  :doc "primary-source URL backing this 縁 (ingest provenance, G7 leg)"}]

 ;; ── derived (transient — computed on read, NEVER persisted; N1/G2) ───────────
 :derived/attrs
 [{:a ":bond/opening-priority"     :doc "Σ inbound accumulation × (1 − openness) — closed concentration → OPENING"}
  {:a ":bond/reach-imposed"        :doc "Σ outbound accumulation load a 取-holder imposes (supplier/funder)"}
  {:a ":bond/dependency-fragility" :doc "Σ :depends-on / :compute-deal load on both endpoints (lock-in cascade)"}]

 ;; ── concentration axes (4) ───────────────────────────────────────────────────
 :concentration/axes [:compute :capital :talent :policy]
 :concentration/route :OPENING

 ;; ── UNREPRESENTABLE by construction (G4) ─────────────────────────────────────
 :forbidden
 {:edges  [":trade" ":buy" ":sell" ":short"]
  :attrs  [":ai/score-of-lab" ":forecast-point" ":capability-grade" ":winner-rank"]
  :reason "chie never trades, never forecasts a winner, never grades capability (N3/G4)."}

 ;; ── cross-actor bridge (chie references; never duplicates) ───────────────────
 :bridge
 {:financials  :kanjo  :supply :kabuto :silicon :handotai :compute-cap :kasa
  :research :kenkyusha :gov-power :keizu :designation :kosatsu :antitrust :abaki}}
